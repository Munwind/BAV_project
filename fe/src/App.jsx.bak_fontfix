  }

  function renderAlerts() {
    return (
      <div className="space-y-5">
        <div className="border-b border-slate-200 pb-5">
          <p className="text-xs uppercase tracking-[0.22em] text-slate-500">Risk monitoring</p>
          <h1 className="font-display mt-2 text-4xl font-semibold tracking-tight text-slate-900">Alerts</h1>
          <p className="mt-3 max-w-2xl text-sm leading-7 text-slate-600">
            Alert queue Ä‘Æ°á»£c sinh tá»« company analytics tháº­t, cÃ³ tÃ­nh Ä‘áº¿n dá»¯ liá»‡u má»›i vÃ  lá»‹ch sá»­ mention.
          </p>
        </div>

        <div className="grid gap-4 xl:grid-cols-[1.1fr_0.9fr]">
          <Panel title="Alert queue" description="CÃ¡c company cáº§n analyst review.">
            <div className="space-y-3">
              {alerts.map((alert) => (
                <button
                  key={alert.id}
                  type="button"
                  onClick={() => setSelectedAlertId(alert.id)}
                  className={`w-full rounded-2xl border px-4 py-4 text-left transition ${
                    selectedAlert?.id === alert.id
                      ? 'border-fuchsia-200 bg-[linear-gradient(135deg,rgba(255,241,242,0.96),rgba(255,255,255,0.96),rgba(250,245,255,0.86))] shadow-[0_18px_36px_-28px_rgba(217,70,239,0.34)]'
                      : 'border-slate-200 bg-white hover:border-sky-200'
                  }`}
                >
                  <div className="flex items-start justify-between gap-3">
                    <div>
                      <p className="text-sm font-medium text-slate-900">{alert.title}</p>
                      <p className="mt-2 text-sm leading-7 text-slate-600">{alert.description}</p>
                      <div className="mt-3 flex flex-wrap gap-2">
                        <Badge tone="default">{alert.companyName}</Badge>
                        <Badge tone={toneForScore(alert.score)}>{alert.sentimentLabel}</Badge>
                        <Badge tone={toneForSeverity(alert.severity)}>{alert.mentions} recent mentions</Badge>
                        <Badge tone="default">{alert.lifetimeMentions} lifetime</Badge>
                        <Badge tone={toneForSeverity(alert.forecastRisk24h)}>24h {formatForecastLabel(alert.forecastRisk24h)}</Badge>
                        <Badge tone={toneForSeverity(alert.forecastRisk7d)}>7d {formatForecastLabel(alert.forecastRisk7d)}</Badge>
                        <Badge tone="warning">Negative ratio {formatPercent(alert.negativeRatio)}</Badge>
                      </div>
                      <p className="mt-3 text-sm leading-7 text-slate-500">{alert.forecastSummary}</p>
                      <div className="mt-4 max-w-[220px]">
                        <SparkBars
                          tone={toneForSeverity(alert.forecastRisk7d || alert.severity)}
                          values={[
                            alert.mentions || 1,
                            alert.lifetimeMentions || 1,
                            alert.score || 1,
                            alert.forecastConfidence ? alert.forecastConfidence * 8 : 2,
                            alert.negativeSignals || 1,
                          ]}
                        />
                      </div>
                    </div>
                    <Badge tone={toneForSeverity(alert.severity)}>{alert.severity}</Badge>
                  </div>
                </button>
              ))}
            </div>
          </Panel>

          <div className="space-y-4">
            <div className="rounded-3xl border border-white/80 bg-[linear-gradient(135deg,rgba(255,241,242,0.98),rgba(255,255,255,0.94),rgba(254,205,211,0.64))] p-5 shadow-[0_18px_48px_-36px_rgba(15,23,42,0.2)]">
              <p className="text-xs uppercase tracking-[0.18em] text-slate-500">Open Alerts</p>
              <p className="mt-3 text-3xl font-semibold text-slate-900">{alerts.length}</p>
            </div>
            <div className="rounded-3xl border border-white/80 bg-[linear-gradient(135deg,rgba(255,251,235,0.98),rgba(255,255,255,0.94),rgba(253,230,138,0.68))] p-5 shadow-[0_18px_48px_-36px_rgba(15,23,42,0.2)]">
              <p className="text-xs uppercase tracking-[0.18em] text-slate-500">High Severity</p>
              <p className="mt-3 text-3xl font-semibold text-slate-900">{alerts.filter((item) => item.severity === 'high').length}</p>
            </div>
            <div className="rounded-3xl border border-white/80 bg-[linear-gradient(135deg,rgba(255,247,237,0.98),rgba(255,255,255,0.94),rgba(251,146,60,0.5))] p-5 shadow-[0_18px_48px_-36px_rgba(15,23,42,0.2)]">
              <p className="text-xs uppercase tracking-[0.18em] text-slate-500">7d High Forecast</p>
              <p className="mt-3 text-3xl font-semibold text-slate-900">{alerts.filter((item) => item.forecastRisk7d === 'high').length}</p>
            </div>
            <div className="rounded-3xl border border-white/80 bg-[linear-gradient(135deg,rgba(240,249,255,0.98),rgba(255,255,255,0.94),rgba(125,211,252,0.56))] p-5 shadow-[0_18px_48px_-36px_rgba(15,23,42,0.2)]">
              <p className="text-xs uppercase tracking-[0.18em] text-slate-500">Historical Coverage</p>
              <p className="mt-3 text-3xl font-semibold text-slate-900">
                {alerts.reduce((sum, item) => sum + (item.lifetimeMentions || 0), 0)}
              </p>
            </div>
            <AlertDonutChart
              high={alerts.filter((item) => item.severity === 'high').length}
              medium={alerts.filter((item) => item.severity === 'medium').length}
              low={alerts.filter((item) => item.severity === 'low').length}
              total={alerts.length}
            />

            {selectedAlert ? (
              <div className="space-y-4 rounded-3xl border border-white/80 bg-[linear-gradient(135deg,rgba(255,255,255,0.98),rgba(240,249,255,0.96),rgba(255,241,242,0.84))] p-5 shadow-[0_18px_48px_-36px_rgba(15,23,42,0.2)]">
                <div>
                  <p className="text-xs uppercase tracking-[0.18em] text-slate-500">Selected Alert</p>
                  <p className="mt-3 text-xl font-semibold text-slate-900">{selectedAlert.companyName}</p>
                  <p className="mt-2 text-sm leading-7 text-slate-600">{selectedAlert.description}</p>
                </div>
                <div className="grid gap-3 sm:grid-cols-2">
                  <div className="rounded-2xl border border-slate-200 bg-white/80 px-4 py-3">
                    <p className="text-xs text-slate-500">Severity</p>
                    <p className="mt-2 text-2xl font-semibold text-slate-900">{selectedAlert.severity}</p>
                  </div>
                  <div className="rounded-2xl border border-slate-200 bg-white/80 px-4 py-3">
                    <p className="text-xs text-slate-500">Model confidence</p>
                    <p className="mt-2 text-2xl font-semibold text-slate-900">{selectedAlert.explainability?.averageModelConfidence || selectedAlert.forecastConfidence}</p>
                  </div>
                </div>
                {renderActionablePanel(selectedAlert)}
                {renderScoreExplainPanel(selectedAlert, { title: 'Why this alert score' })}
                {renderEvidencePanel(selectedAlert)}
              </div>
            ) : null}
          </div>
        </div>
      </div>
    )
  }

  function renderMarketView() {
    const hasData = selectedMarketCandles.length > 0
    const windowSize = 72
    const maxOffset = Math.max(0, selectedMarketCandles.length - windowSize)
    const normalizedOffset = Math.min(maxOffset, Math.max(0, marketOffset))
    const visibleCandles = hasData
      ? selectedMarketCandles.slice(
          Math.max(0, selectedMarketCandles.length - windowSize - normalizedOffset),
          selectedMarketCandles.length - normalizedOffset,
        )
      : []

    const prices = visibleCandles.map((item) => [item.low, item.high]).flat()
    const minPrice = hasData ? Math.min(...prices, ...selectedMarketForecast.map((item) => item.lower)) : 0
    const maxPrice = hasData ? Math.max(...prices, ...selectedMarketForecast.map((item) => item.upper)) : 1
    const chartRange = Math.max(1, maxPrice - minPrice)
    const priceHeight = 286
    const volumeHeight = 78
    const chartWidth = 980
    const chartPadding = { top: 14, right: 72, bottom: 18, left: 8 }
    const plotX = chartPadding.left
    const plotY = chartPadding.top
    const plotWidth = chartWidth
    const pricePlotHeight = priceHeight
    const volumeTop = plotY + pricePlotHeight + 12
    const candleGap = chartWidth / Math.max(1, visibleCandles.length || 1)
    const candleWidth = Math.max(4, candleGap * 0.68)
    const volumeMax = hasData ? Math.max(...visibleCandles.map((item) => item.volume), 1) : 1

    const yForPrice = (value) => plotY + (pricePlotHeight - ((value - minPrice) / chartRange) * pricePlotHeight)
    const xForCandle = (index) => plotX + index * candleGap + candleGap * 0.5
    const chartSvgWidth = Math.max(1120, chartWidth + chartPadding.left + chartPadding.right + 120)
    const chartSvgHeight = 460
    const hoverCandle = marketHoverIndex >= 0 ? visibleCandles[marketHoverIndex] : null
    const hoverX = marketHoverIndex >= 0 ? xForCandle(marketHoverIndex) : null
    const rsi = computeRsi(visibleCandles)
    const marketCap = MARKET_CAP_BY_SYMBOL[selectedMarketSymbol] || 0
    const trendUp = (selectedMarketQuote?.change || 0) >= 0
    const selectedConf = Math.max(58, Math.min(96, 68 + Math.round(Math.abs(selectedMarketQuote?.changePct || 0) * 4)))
    const foreignNet = Math.round((selectedMarketQuote?.avgVolume || 0) * 0.08) * (trendUp ? 1 : -1)
    const breadthAdv = MARKET_SYMBOLS.filter((item) => {
      const candles = marketSeriesBySymbol[item.symbol]?.candles || []
      if (candles.length < 2) return false
      return candles[candles.length - 1].close >= candles[candles.length - 2].close
    }).length
    const breadthDec = Math.max(0, MARKET_SYMBOLS.length - breadthAdv)
    const ma20 = visibleCandles.map((_, idx) => {
      const window = visibleCandles.slice(Math.max(0, idx - 19), idx + 1)
      return window.reduce((sum, c) => sum + c.close, 0) / window.length
    })
    const ma50 = visibleCandles.map((_, idx) => {
      const window = visibleCandles.slice(Math.max(0, idx - 49), idx + 1)
      return window.reduce((sum, c) => sum + c.close, 0) / window.length
    })

    return (
      <div className="market-terminal rounded-3xl border border-white/10 p-4 sm:p-5">
        <div className="market-ticker mb-4 flex items-center gap-4 overflow-x-auto rounded-xl border border-white/10 px-3 py-2 text-xs">
          <span className="shrink-0 text-cyan-300">LIVE HOSE</span>
          {MARKET_SYMBOLS.map((item) => {
            const candles = marketSeriesBySymbol[item.symbol]?.candles || []
            const last = candles[candles.length - 1]
            const prev = candles[candles.length - 2] || last
            const pct = prev?.close ? ((last?.close || 0) - prev.close) / prev.close * 100 : 0
            return <span key={`ticker-${item.symbol}`} className={`shrink-0 ${pct >= 0 ? 'text-emerald-300' : 'text-rose-300'}`}>{item.symbol} {pct >= 0 ? '+' : ''}{pct.toFixed(2)}%</span>
          })}
        </div>

        <div className="mb-4 grid grid-cols-1 gap-3 rounded-xl border border-white/10 bg-white/5 p-3 md:grid-cols-[1.2fr_1fr_auto_auto]">
          <div className="text-sm text-slate-200">VNINDEX <span className="font-semibold">1,284.32</span> <span className="text-emerald-300">+0.84%</span></div>
          <div className="text-sm text-slate-300">HOSE | {selectedMarketQuote?.regularMarketTime || marketSnapshot.fetchedAt || '--'}</div>
          <div className={`rounded-md border px-2 py-1 text-xs ${marketStatus === 'error' ? 'border-rose-300/35 bg-rose-500/10 text-rose-200' : marketStatus === 'loading' ? 'border-amber-300/35 bg-amber-500/10 text-amber-200' : 'border-cyan-300/30 bg-cyan-400/10 text-cyan-200'}`}>{marketStatus === 'error' ? 'Feed Delay' : marketStatus === 'loading' ? 'Syncing' : 'Market Open'}</div>
          <div className="rounded-md border border-white/15 bg-white/5 px-2 py-1 text-xs text-slate-300">🔔 4</div>
        </div>

        <div className="grid gap-4 xl:grid-cols-[280px_minmax(0,1fr)_320px]">
          <aside className="rounded-2xl border border-white/10 bg-white/5 p-3">
            <p className="mb-3 text-xs uppercase tracking-[0.14em] text-slate-400">Watchlist</p>
            <div className="space-y-2">
              {MARKET_SYMBOLS.map((item) => {
                const candles = marketSeriesBySymbol[item.symbol]?.candles || []
                const last = candles[candles.length - 1]
                const prev = candles[candles.length - 2] || last
                const pct = prev?.close ? ((last?.close || 0) - prev.close) / prev.close * 100 : 0
                const up = pct >= 0
                const active = selectedMarketSymbol === item.symbol
                const spark = candles.slice(-18)
                const min = Math.min(...spark.map((c) => c.close), 0)
                const max = Math.max(...spark.map((c) => c.close), 1)
                return (
                  <button key={item.symbol} type="button" onClick={() => setSelectedMarketSymbol(item.symbol)} className={`w-full rounded-xl border p-2.5 text-left ${active ? 'border-cyan-300/40 bg-cyan-500/12' : 'border-white/10 bg-slate-900/30'}`}>
                    <div className="flex items-center justify-between gap-2">
                      <div>
                        <p className="text-sm font-semibold text-slate-100">{item.symbol}</p>
                        <p className="text-[11px] text-slate-400">{item.name}</p>
                      </div>
                      <div className="text-right">
                        <p className="text-sm text-slate-200">{formatVnd(last?.close || 0)}</p>
                        <p className={`text-xs ${up ? 'text-emerald-300' : 'text-rose-300'}`}>{up ? '+' : ''}{pct.toFixed(2)}%</p>
                      </div>
                    </div>
                    <svg width="100%" height="26" viewBox="0 0 100 26" className="mt-1">
                      <polyline fill="none" stroke={up ? 'rgba(16,185,129,0.9)' : 'rgba(244,63,94,0.9)'} strokeWidth="1.5" points={spark.map((c, i) => `${(i / Math.max(1, spark.length - 1)) * 100},${24 - ((c.close - min) / Math.max(1, max - min)) * 20}`).join(' ')} />
                    </svg>
                  </button>
                )
              })}
            </div>
          </aside>

          <section className="rounded-2xl border border-white/10 bg-white/5 p-3">
            <div className="mb-3 flex flex-wrap items-center justify-between gap-2">
              <div>
                <p className="text-xs uppercase tracking-[0.14em] text-slate-400">{selectedMarketMeta.exchange}</p>
                <p className="text-xl font-semibold text-slate-50">{selectedMarketMeta.symbol} - {selectedMarketMeta.name}</p>
              </div>
              <div className={`rounded-md border px-2 py-1 text-xs ${trendUp ? 'border-emerald-300/40 bg-emerald-500/10 text-emerald-300' : 'border-rose-300/40 bg-rose-500/10 text-rose-300'}`}>
                {trendUp ? '+' : ''}{(selectedMarketQuote?.changePct || 0).toFixed(2)}%
              </div>
            </div>

            <div className="mb-3 flex flex-wrap gap-1.5">
              {['1m', '5m', '15m', '1H', '4H', '1D', '1W', '1M'].map((item) => (
                <button key={item} type="button" onClick={() => setMarketInterval(item.toLowerCase())} className={`rounded-md border px-2 py-1 text-xs ${marketInterval === item.toLowerCase() ? 'border-cyan-300/45 bg-cyan-500/15 text-cyan-200' : 'border-white/10 text-slate-300'}`}>{item}</button>
              ))}
              {['1d', '5d', '1mo', '3mo', '6mo', '1y'].map((range) => (
                <button key={range} type="button" onClick={() => { setMarketRange(range); setMarketOffset(0) }} className={`rounded-md border px-2 py-1 text-xs ${marketRange === range ? 'border-emerald-300/40 bg-emerald-500/14 text-emerald-200' : 'border-white/10 text-slate-300'}`}>{range}</button>
              ))}
              <button type="button" onClick={() => loadMarketSnapshot()} className="rounded-md border border-white/15 px-2 py-1 text-xs text-slate-200">Refresh</button>
            </div>

            <div className="mb-3 grid gap-2 sm:grid-cols-4">
              <div className="market-metric"><span>Open</span><b>{formatVnd(selectedMarketQuote?.open || 0)}</b></div>
              <div className="market-metric"><span>High</span><b>{formatVnd(selectedMarketQuote?.high || 0)}</b></div>
              <div className="market-metric"><span>Low</span><b>{formatVnd(selectedMarketQuote?.low || 0)}</b></div>
              <div className="market-metric"><span>Volume</span><b>{formatCompact(selectedMarketQuote?.avgVolume || 0)}</b></div>
              <div className="market-metric"><span>Market cap</span><b>{formatCompact(marketCap)}</b></div>
              <div className="market-metric"><span>RSI</span><b>{rsi.toFixed(1)}</b></div>
              <div className="market-metric"><span>Predict</span><b>{formatVnd(selectedMarketForecast[0]?.center || 0)}</b></div>
              <div className="market-metric"><span>Confidence</span><b>{selectedConf}%</b></div>
            </div>

            {hasData ? <div className="overflow-x-auto rounded-xl border border-white/10 bg-[#0B1220]/80">
              <svg width={chartSvgWidth} height={chartSvgHeight} viewBox={`0 0 ${chartSvgWidth} ${chartSvgHeight}`} onMouseLeave={() => setMarketHoverIndex(-1)}>
                <rect x={plotX} y={plotY} width={plotWidth} height={pricePlotHeight} fill="rgba(11,18,32,0.95)" />
                {Array.from({ length: 6 }).map((_, idx) => <line key={`g-${idx}`} x1={plotX} y1={plotY + (pricePlotHeight / 5) * idx} x2={plotX + plotWidth} y2={plotY + (pricePlotHeight / 5) * idx} stroke="rgba(148,163,184,0.16)" />)}
                {visibleCandles.map((candle, idx) => {
                  const x = xForCandle(idx)
                  const openY = yForPrice(candle.open)
                  const closeY = yForPrice(candle.close)
                  const highY = yForPrice(candle.high)
                  const lowY = yForPrice(candle.low)
                  const up = candle.close >= candle.open
                  const color = up ? 'rgba(16,185,129,0.95)' : 'rgba(244,63,94,0.95)'
                  const vh = (candle.volume / volumeMax) * (volumeHeight - 6)
                  return <g key={`mk-${candle.ts}-${idx}`} onMouseEnter={() => setMarketHoverIndex(idx)}>
                    <line x1={x} y1={highY} x2={x} y2={lowY} stroke={color} />
                    <rect x={x - candleWidth / 2} y={Math.min(openY, closeY)} width={candleWidth} height={Math.max(1.5, Math.abs(openY - closeY))} fill={color} opacity="0.88" />
                    <rect x={x - candleWidth / 2} y={volumeTop + volumeHeight - 2 - vh} width={candleWidth} height={vh} fill={color} opacity="0.35" />
                    {idx > 0 ? <line x1={xForCandle(idx - 1)} y1={yForPrice(ma20[idx - 1])} x2={x} y2={yForPrice(ma20[idx])} stroke="rgba(34,211,238,0.8)" strokeWidth="1.2" /> : null}
                    {idx > 0 ? <line x1={xForCandle(idx - 1)} y1={yForPrice(ma50[idx - 1])} x2={x} y2={yForPrice(ma50[idx])} stroke="rgba(251,191,36,0.75)" strokeWidth="1.2" /> : null}
                  </g>
                })}
                {hoverCandle && hoverX != null ? <g>
                  <line x1={hoverX} y1={plotY} x2={hoverX} y2={volumeTop + volumeHeight} stroke="rgba(226,232,240,0.35)" strokeDasharray="3 4" />
                  <rect x={hoverX + 10} y={plotY + 8} width="190" height="118" rx="8" fill="rgba(11,18,32,0.94)" stroke="rgba(148,163,184,0.35)" />
                  <text x={hoverX + 18} y={plotY + 28} fill="#cbd5e1" fontSize="11">O: {formatVnd(hoverCandle.open)}</text>
                  <text x={hoverX + 18} y={plotY + 45} fill="#cbd5e1" fontSize="11">H: {formatVnd(hoverCandle.high)}</text>
                  <text x={hoverX + 18} y={plotY + 62} fill="#cbd5e1" fontSize="11">L: {formatVnd(hoverCandle.low)}</text>
                  <text x={hoverX + 18} y={plotY + 79} fill="#cbd5e1" fontSize="11">C: {formatVnd(hoverCandle.close)}</text>
                  <text x={hoverX + 18} y={plotY + 98} fill="#93a4b8" fontSize="10">{hoverCandle.timeLabel || hoverCandle.ts}</text>
                </g> : null}
              </svg>
            </div> : <div className="rounded-xl border border-white/10 bg-slate-900/40 p-6 text-sm text-slate-300">{marketError || 'Không có dữ liệu realtime cho symbol này.'}</div>}

            <div className="mt-3 flex justify-between text-xs text-slate-400">
              <span>MA20: Cyan · MA50: Amber</span>
              <span>{marketSnapshot.fetchedAt ? `Fetched: ${marketSnapshot.fetchedAt}` : ''}</span>
            </div>
          </section>

          <aside className="space-y-3 rounded-2xl border border-white/10 bg-white/5 p-3">
            <p className="text-sm font-semibold text-slate-100">AI Market Assistant</p>
            <div className="market-ai-card"><span>Sentiment analysis</span><b className={trendUp ? 'text-emerald-300' : 'text-rose-300'}>{trendUp ? 'Positive bias' : 'Risk-off bias'}</b><div className="market-bar"><i style={{ width: `${Math.max(44, Math.min(86, 52 + Math.abs(selectedMarketQuote?.changePct || 0) * 12))}%` }} /></div></div>
            <div className="market-ai-card"><span>Predicted trend</span><b className="text-cyan-300">{selectedMarketForecast[0]?.center > (selectedMarketQuote?.close || 0) ? 'Mild upside 4H' : 'Sideway / pullback'}</b><div className="market-bar"><i style={{ width: `${selectedConf}%` }} /></div></div>
            <div className="market-ai-card"><span>News summary</span><p className="text-xs text-slate-300">Dòng tiền tập trung bluechip HOSE; nhóm ngân hàng giữ nhịp, bất động sản hồi phục chọn lọc.</p></div>
            <div className="market-ai-card"><span>Anomaly detection</span><b className="text-amber-300">{Math.abs(selectedMarketQuote?.changePct || 0) > 2 ? 'Volume spike detected' : 'No critical anomaly'}</b><div className="market-bar"><i style={{ width: `${Math.max(22, Math.min(80, Math.abs(selectedMarketQuote?.changePct || 0) * 20))}%` }} /></div></div>
            <div className="grid grid-cols-2 gap-2 text-xs">
              <div className="rounded-lg border border-white/10 bg-slate-900/40 p-2 text-slate-300">Foreign net<br /><span className={foreignNet >= 0 ? 'text-emerald-300' : 'text-rose-300'}>{foreignNet >= 0 ? '+' : ''}{formatCompact(foreignNet)}</span></div>
              <div className="rounded-lg border border-white/10 bg-slate-900/40 p-2 text-slate-300">Breadth<br /><span className="text-cyan-300">{breadthAdv}↑ / {breadthDec}↓</span></div>
            </div>
          </aside>
        </div>

        <div className="mt-4 rounded-xl border border-white/10 bg-white/5 p-3">
          <p className="mb-2 text-xs uppercase tracking-[0.14em] text-slate-400">Sector performance</p>
          <div className="grid grid-cols-2 gap-2 md:grid-cols-6">
            {[
              ['Ngân hàng', 1.24],
              ['Bất động sản', -0.63],
              ['Bán lẻ', 0.92],
              ['Thép', -0.35],
              ['Công nghệ', 1.76],
              ['Năng lượng', 0.41],
            ].map(([label, change]) => (
              <div key={label} className={`rounded-lg border p-2 text-xs ${change >= 0 ? 'border-emerald-300/20 bg-emerald-500/10 text-emerald-200' : 'border-rose-300/20 bg-rose-500/10 text-rose-200'}`}>
                <p className="text-slate-300">{label}</p>
                <p className="mt-1 font-semibold">{change >= 0 ? '+' : ''}{change}%</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    )
  }
function _renderCompare() {
    return (
      <div className="space-y-5">
        <div className="border-b border-slate-200 pb-5">
          <p className="text-xs uppercase tracking-[0.22em] text-slate-500">Watchlist benchmarking</p>
          <h1 className="font-display mt-2 text-4xl font-semibold tracking-tight text-slate-900">Compare</h1>
          <p className="mt-3 max-w-2xl text-sm leading-7 text-slate-600">
            So sÃ¡nh tá»‘i Ä‘a 3 thÆ°Æ¡ng hiá»‡u theo mentions, negative ratio, forecast risk vÃ  top topics.
          </p>
        </div>

        <Panel title="Watchlist" description="Pick up to 3 companies for side-by-side comparison.">
          <div className="flex flex-wrap gap-2">
            {companies.slice(0, 18).map((company) => (
              <button
                key={`watch-${company.key}`}
                type="button"
                onClick={() => toggleWatchlist(company.key)}
                className={`rounded-2xl border px-3 py-2 text-xs font-medium ${
                  watchlistKeys.includes(company.key)
                    ? 'border-fuchsia-200 bg-[linear-gradient(90deg,rgba(224,242,254,0.96),rgba(243,232,255,0.86))] text-slate-900'
                    : 'border-slate-200 bg-white/80 text-slate-500'
                }`}
              >
                {company.name}
              </button>
            ))}
          </div>
        </Panel>

        <div className="grid gap-4 xl:grid-cols-3">
          {_compareCompanies.map((company) => (
            <div key={`compare-${company.key}`} className="rounded-3xl border border-white/80 bg-[linear-gradient(135deg,rgba(255,255,255,0.98),rgba(240,249,255,0.94),rgba(255,247,237,0.86))] p-5 shadow-[0_18px_48px_-36px_rgba(15,23,42,0.2)]">
              <div className="flex items-start justify-between gap-3">
                <div>
                  <p className="text-lg font-semibold text-slate-950">{company.name}</p>
                  <p className="mt-1 text-sm text-slate-500">{company.industry}</p>
                </div>
                <Badge tone={toneForSeverity(company.forecastRisk7d)}>7d {formatForecastLabel(company.forecastRisk7d)}</Badge>
              </div>

              <div className="mt-4 grid gap-3 sm:grid-cols-2">
                <div className="rounded-2xl border border-slate-200 bg-white/80 px-4 py-3">
                  <p className="text-xs text-slate-500">Mentions</p>
                  <p className="mt-2 text-2xl font-semibold text-slate-900">{company.mentions}</p>
                </div>
                <div className="rounded-2xl border border-slate-200 bg-white/80 px-4 py-3">
                  <p className="text-xs text-slate-500">Negative ratio</p>
                  <p className="mt-2 text-2xl font-semibold text-slate-900">{formatPercent(company.negativeRatio)}</p>
                </div>
                <div className="rounded-2xl border border-slate-200 bg-white/80 px-4 py-3">
                  <p className="text-xs text-slate-500">Forecast</p>
                  <p className="mt-2 text-2xl font-semibold text-slate-900">{formatForecastLabel(company.forecastRisk7d)}</p>
                </div>
                <div className="rounded-2xl border border-slate-200 bg-white/80 px-4 py-3">
                  <p className="text-xs text-slate-500">Top source</p>
                  <p className="mt-2 text-lg font-semibold text-slate-900">{company.explainability?.strongestSource || 'N/A'}</p>
                </div>
              </div>

              <div className="mt-4">
                <p className="text-xs uppercase tracking-[0.16em] text-slate-500">Top topics</p>
                <div className="mt-3 flex flex-wrap gap-2">
                  {(company.topTopics || []).map((topic) => (
                    <Badge key={`topic-${company.key}-${topic}`} tone="default">{topic}</Badge>
                  ))}
                </div>
              </div>

              <div className="mt-4 rounded-2xl border border-slate-200 bg-white/80 px-4 py-3">
                <p className="text-xs uppercase tracking-[0.16em] text-slate-500">Action bias</p>
                <p className="mt-2 text-sm leading-7 text-slate-700">{company.actionable?.recommendedAction}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    )
  }

  function renderChatMessage(message) {
    const isUser = message.role === 'user'

    return (
      <div key={message.id} className={`flex ${isUser ? 'justify-end' : 'justify-start'}`}>
        <div className={`max-w-[90%] ${isUser ? 'items-end' : 'items-start'} flex flex-col gap-2`}>
          <div className={`flex items-center gap-2 px-1 ${isUser ? 'flex-row-reverse' : ''}`}>
            <span
              className={`flex size-8 items-center justify-center rounded-2xl text-[11px] font-semibold uppercase tracking-[0.14em] ${
                isUser
                  ? 'bg-[linear-gradient(135deg,rgba(14,165,233,1),rgba(59,130,246,0.96),rgba(217,70,239,0.92))] text-white shadow-[0_12px_24px_-12px_rgba(59,130,246,0.72)]'
                  : 'border border-white/80 bg-[linear-gradient(135deg,rgba(255,255,255,0.98),rgba(224,242,254,0.92),rgba(255,237,213,0.88))] text-slate-700 shadow-[0_12px_24px_-12px_rgba(14,165,233,0.3)]'
              }`}
            >
              {isUser ? 'You' : 'AI'}
            </span>
            <span className="text-[11px] font-medium uppercase tracking-[0.16em] text-slate-400">
              {isUser ? 'Analyst Prompt' : 'AI Assistant'}
            </span>
          </div>

          <div
            className={`relative overflow-hidden rounded-[24px] px-4 py-3 text-sm leading-7 shadow-[0_20px_44px_-28px_rgba(15,23,42,0.24)] ${
              isUser
                ? 'bg-[linear-gradient(135deg,rgba(14,165,233,0.98),rgba(59,130,246,0.94),rgba(217,70,239,0.9),rgba(251,146,60,0.82))] text-white'
                : 'border border-white/80 bg-[linear-gradient(135deg,rgba(236,254,255,0.96),rgba(255,255,255,0.97),rgba(250,245,255,0.9),rgba(255,237,213,0.84))] text-slate-800'
            }`}
          >
            <div className="pointer-events-none absolute inset-x-0 top-0 h-px bg-white/60" />
            <div className="whitespace-pre-line">{message.content}</div>
          </div>

          {!isUser && message.references?.length ? (
            <div className="w-full rounded-[22px] border border-white/80 bg-[linear-gradient(135deg,rgba(255,255,255,0.94),rgba(240,249,255,0.92),rgba(255,247,237,0.86))] p-3 shadow-[0_18px_36px_-28px_rgba(15,23,42,0.2)]">
              <div className="flex items-center justify-between gap-3">
                <p className="text-[11px] font-medium uppercase tracking-[0.16em] text-slate-400">References</p>
                <Badge tone="info">{message.references.length} sources</Badge>
              </div>
              <div className="mt-2 space-y-2">
                {message.references.map((reference) => (
                  <a
                    key={`${message.id}-${reference.url}`}
                    href={reference.url}
                    target="_blank"
                    rel="noreferrer"
                    className="block rounded-2xl border border-slate-200 bg-[linear-gradient(90deg,rgba(255,255,255,0.98),rgba(240,249,255,0.92),rgba(255,237,213,0.82))] px-3 py-2.5 transition hover:border-sky-200 hover:bg-[linear-gradient(90deg,rgba(224,242,254,0.92),rgba(255,255,255,0.96),rgba(250,245,255,0.82))]"
                  >
                    <p className="text-sm font-medium text-slate-900">{reference.title}</p>
                    <p className="mt-1 text-xs text-slate-500">
                      {reference.source || 'Unknown source'}  {formatDate(reference.published_at)}
                    </p>
                  </a>
                ))}
              </div>
            </div>
          ) : null}
        </div>
      </div>
    )
  }

  return (
    <div className="app-shell min-h-screen bg-transparent px-4 py-4 text-slate-900 lg:px-6">
      {mobileNavOpen ? (
