                      {activeView === 'companies' && selectedCompany ? `Äang phÃ¢n tÃ­ch: ${selectedCompany.name}` : 'Äang á»Ÿ cháº¿ Ä‘á»™ phÃ¢n tÃ­ch tá»•ng quan'}
