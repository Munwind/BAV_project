                          </p>
                        </div>
                        <ChevronRight className="mt-1 size-4 text-slate-400" />
                      </div>
                    </a>
                  ))}
                </div>
              </div>
            ) : (
              <p className="text-sm text-slate-500">KhÃ´ng cÃ³ company Ä‘Æ°á»£c chá»n.</p>
            )}
          </Panel>
